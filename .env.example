# =============================================================================
# FEA CRM credentials
# Used by scripts/probe-crm.ts to discover CRM properties + lead endpoint shape.
# DO NOT commit a real .env — only .env.example is tracked.
# =============================================================================

# Required ─ get these from FEA's CRM admin (BrokerDesk)
CRM_BASE_URL=https://feaprop.brokerdesk.ae

# Read key — public API key for GET /api/v1/public/listings
CRM_API_KEY=your-read-api-key-here

# Lead-intake key — generated separately under
# BrokerDesk admin → Integrations → Lead Intake API
# Used to POST website form submissions to /api/v1/public/intake/leads
CRM_LEAD_API_KEY=your-lead-intake-key-here

# Optional ─ adjust if FEA's CRM uses non-default conventions
# Header used for authentication (e.g. Authorization, x-api-key, X-Auth-Token)
# CRM_AUTH_HEADER=Authorization
# Prefix prepended to the key (e.g. "Bearer", "Token", or empty for raw key)
# CRM_AUTH_PREFIX=Bearer

# Endpoint paths (relative to CRM_BASE_URL)
# CRM_PROPERTIES_PATH=/properties
# CRM_LEAD_PATH=/leads
